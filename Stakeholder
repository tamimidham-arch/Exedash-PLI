<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Stakeholder Mapping - Sub Dashboard</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', sans-serif; background: #f0f2f5; padding: 20px; }
        .dashboard-container { max-width: 1200px; margin: 0 auto; }
        .header { background: linear-gradient(135deg, #17a2b8, #0f7b8c); color: white; padding: 20px; border-radius: 15px; margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; }
        .back-btn { background: rgba(255,255,255,0.2); color: white; border: none; padding: 8px 16px; border-radius: 8px; cursor: pointer; }
        .card { background: white; border-radius: 15px; padding: 20px; margin-bottom: 20px; }
        table { width: 100%; border-collapse: collapse; }
        th, td { padding: 10px; text-align: left; border-bottom: 1px solid #e9ecef; }
        .priority-high { background: #dc3545; color: white; padding: 2px 8px; border-radius: 20px; font-size: 11px; display: inline-block; }
        .priority-medium { background: #ffc107; padding: 2px 8px; border-radius: 20px; font-size: 11px; display: inline-block; }
        .priority-low { background: #28a745; color: white; padding: 2px 8px; border-radius: 20px; font-size: 11px; display: inline-block; }
        .loader { text-align: center; padding: 40px; }
        @media (max-width: 800px) { .matrix-container canvas { width: 100% !important; height: auto !important; } }
    </style>
</head>
<body>
    <div class="dashboard-container">
        <div class="header">
            <div><h1><i class="fas fa-handshake"></i> Stakeholder Mapping</h1></div>
            <div><span id="data-status" class="status-badge" style="background:rgba(255,255,255,0.2); padding:4px 10px; border-radius:20px;">Memuat...</span><button class="back-btn" onclick="window.location.href='../index.html'"><i class="fas fa-arrow-left"></i> Kembali</button></div>
        </div>
        <div id="dashboard-content"><div class="loader"><i class="fas fa-spinner fa-pulse"></i> Memuat data...</div></div>
    </div>
    <script>
        const API_URL = 'https://script.google.com/macros/s/AKfycbywHucFlh5aJAPbVMUWGA_REGi9lrax2IjYMbPtHJoMTIYqIriHeRFnjygQMbICNJphhg/exec';
        let data = [];
        async function fetchData() {
            try {
                const res = await fetch(`${API_URL}?sheet=STAKEHOLDER`);
                const json = await res.json();
                if (json.data && json.data.length > 1) {
                    const headers = json.data[0];
                    const rows = json.data.slice(1).filter(r => r[0]);
                    data = rows.map(r => { let obj = {}; headers.forEach((h,i) => { if(h) obj[h] = r[i] || ''; }); return obj; });
                    document.getElementById('data-status').innerHTML = '<i class="fas fa-check-circle"></i> Online';
                } else { loadDemo(); }
                render();
            } catch(e) { loadDemo(); render(); document.getElementById('data-status').innerHTML = '<i class="fas fa-exclamation-triangle"></i> Demo'; }
        }
        function loadDemo() {
            data = [
                { Nama: 'Follower Sosmed', Kategori: 'Sosmed', Prioritas: '4', Komunikasi: '5', Intensitas: '36', Frekuensi: 'Harian', Metode: 'Media sosial', Rekomendasi: 'Tingkatkan engagement' },
                { Nama: 'Pemkot Depok', Kategori: 'Instansi', Prioritas: '5', Komunikasi: '5', Intensitas: '0', Frekuensi: 'Bulanan', Metode: 'Offline', Rekomendasi: 'Koordinasi rokok ilegal' },
                { Nama: 'Pemkot Bogor', Kategori: 'Instansi', Prioritas: '4', Komunikasi: '5', Intensitas: '0', Frekuensi: 'Semester', Metode: 'Offline', Rekomendasi: 'Audensi rutin' }
            ];
        }
        function render() {
            if(data.length===0){ document.getElementById('dashboard-content').innerHTML='<div class="loader">Belum ada data</div>'; return; }
            const html = `<div class="card"><h3>Matriks Prioritas</h3><canvas id="matrix-chart" width="800" height="400" style="width:100%; background:#f8f9fa; border-radius:10px;"></canvas><div style="text-align:center; margin-top:10px;">⬆️ Prioritas &nbsp; ➡️ Komunikasi</div></div><div class="card"><h3>Daftar Stakeholder</h3><table><thead><tr><th>Stakeholder</th><th>Kategori</th><th>Prioritas</th><th>Frekuensi</th><th>Metode</th><th>Rekomendasi</th></tr></thead><tbody id="table-body"></tbody></table></div>`;
            document.getElementById('dashboard-content').innerHTML = html;
            const canvas = document.getElementById('matrix-chart');
            const ctx = canvas.getContext('2d');
            const w = canvas.width = 800, h = canvas.height = 400;
            ctx.fillStyle = '#f8f9fa'; ctx.fillRect(0,0,w,h);
            ctx.strokeStyle = '#dee2e6';
            for(let i=1;i<=5;i++){ ctx.beginPath(); ctx.moveTo(i*w/5,0); ctx.lineTo(i*w/5,h); ctx.stroke(); ctx.beginPath(); ctx.moveTo(0,i*h/5); ctx.lineTo(w,i*h/5); ctx.stroke(); }
            data.forEach(s => {
                const x = ((parseFloat(s.Komunikasi)||3)/5)*w;
                const y = h-((parseFloat(s.Prioritas)||3)/5)*h;
                const radius = 5 + (Math.min(20, parseFloat(s.Intensitas)||0)/10);
                ctx.beginPath(); ctx.arc(x,y,radius,0,2*Math.PI);
                ctx.fillStyle = (parseFloat(s.Prioritas)||0)>=4 ? '#dc3545' : (parseFloat(s.Prioritas)||0)>=3 ? '#ffc107' : '#28a745';
                ctx.fill();
                ctx.fillStyle = 'white'; ctx.font = '10px sans-serif'; ctx.fillText((s.Nama||'').substring(0,12), x-15, y-radius-3);
            });
            let tableHtml = '';
            data.forEach(s => {
                const p = parseFloat(s.Prioritas)||3;
                const cls = p>=4 ? 'priority-high' : (p>=3 ? 'priority-medium' : 'priority-low');
                const txt = p>=4 ? 'Tinggi' : (p>=3 ? 'Sedang' : 'Rendah');
                tableHtml += `<tr><td><strong>${s.Nama}</strong></td><td>${s.Kategori}</td><td><span class="${cls}">${txt}</span></td><td>${s.Frekuensi||'-'}</td><td>${s.Metode||'-'}</td><td style="color:#28a745;">${s.Rekomendasi||'-'}</td></tr>`;
            });
            document.getElementById('table-body').innerHTML = tableHtml;
        }
        fetchData();
    </script>
</body>
</html>
