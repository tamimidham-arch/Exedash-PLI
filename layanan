        function generateInsights() {
            // Generate insights based on channel and category data
            let insights = [];
            
            // Channel insights
            if (channelData.length > 0 && channelConfig.length > 0) {
                const latestChannel = channelData[channelData.length - 1];
                const prevChannel = channelData[channelData.length - 2];
                
                if (latestChannel) {
                    const topChannelIndex = latestChannel.values.indexOf(Math.max(...latestChannel.values));
                    const topChannel = channelConfig[topChannelIndex];
                    const topValue = latestChannel.values[topChannelIndex];
                    
                    insights.push(`📊 **Channel Teratas**: ${topChannel} mendominasi dengan ${topValue} layanan di bulan ${latestChannel.bulan}.`);
                    
                    if (prevChannel) {
                        const growthRates = latestChannel.values.map((val, i) => {
                            const prevVal = prevChannel.values[i] || 0;
                            return prevVal > 0 ? ((val - prevVal) / prevVal * 100) : 0;
                        });
                        const highestGrowthIndex = growthRates.indexOf(Math.max(...growthRates));
                        if (highestGrowthIndex >= 0 && growthRates[highestGrowthIndex] > 10) {
                            insights.push(`📈 **Pertumbuhan Tertinggi**: ${channelConfig[highestGrowthIndex]} meningkat ${Math.round(growthRates[highestGrowthIndex])}% dibanding bulan sebelumnya.`);
                        }
                    }
                }
            }
            
            // Category insights
            if (dataKategoriLayanan.length > 0) {
                const topCategory = dataKategoriLayanan[0];
                insights.push(`🏷️ **Topik Terbanyak**: "${topCategory.nama}" menjadi topik layanan tertinggi dengan total ${topCategory.total} pertanyaan.`);
                
                if (topCategory.nama === 'REGISTRASI IMEI') {
                    insights.push(`📱 Registrasi IMEI masih menjadi perhatian utama masyarakat. Pastikan sosialisasi terus ditingkatkan.`);
                } else if (topCategory.nama === 'INFORMASI LAINNYA') {
                    insights.push(`ℹ️ Tingginya "Informasi Lainnya" mengindikasikan perlunya penyederhanaan informasi dan peningkatan FAQ.`);
                } else if (topCategory.nama === 'PENGADUAN') {
                    insights.push(`⚠️ Aduan masyarakat cukup tinggi, perlu evaluasi responsivitas layanan dan follow-up yang lebih cepat.`);
                }
                
                // Check for rising categories
                if (dataKategoriLayanan.length >= 2) {
                    const secondCategory = dataKategoriLayanan[1];
                    insights.push(`📌 Kategori "${secondCategory.nama}" juga cukup signifikan dengan ${secondCategory.total} total layanan.`);
                }
            }
            
            // Trend insights
            if (trenPerubahan && trenPerubahan !== '') {
                const trendValue = parseInt(trenPerubahan.replace(/[^0-9-]/g, '')) || 0;
                if (trendValue > 0) {
                    insights.push(`📈 **Tren Positif**: Total layanan bulanan meningkat ${Math.abs(trendValue)} dibanding bulan sebelumnya.`);
                } else if (trendValue < 0) {
                    insights.push(`📉 **Tren Menurun**: Total layanan bulanan turun ${Math.abs(trendValue)}. Perlu analisis penyebab penurunan.`);
                }
            }
            
            // Average time insight
            if (ytdAvgTime !== '--:--:--') {
                insights.push(`⏱️ **Waktu Respons**: Rata-rata waktu layanan YTD ${ytdAvgTime}, target untuk ditingkatkan menjadi < 15 menit.`);
            }
            
            if (insights.length === 0) {
                insights.push('📝 Belum ada data cukup untuk menghasilkan insight. Silakan periksa koneksi data.');
            }
            
            return insights;
        }
        
