                    <div id="map"></div>
                    <div class="map-legend">
                        <div class="legend-item"><div class="legend-marker small"></div> <span>Frekuensi Rendah (1-2 aduan)</span></div>
                        <div class="legend-item"><div class="legend-marker medium"></div> <span>Frekuensi Sedang (3-4 aduan)</span></div>
                        <div class="legend-item"><div class="legend-marker large"></div> <span>Frekuensi Tinggi (5+ aduan)</span></div>
                        <div class="legend-item"><i class="fas fa-info-circle"></i> <span>Hover = detail | Klik = info lengkap</span></div>
                    </div>
                </div>
            `;
            
            document.getElementById('dashboard-content').innerHTML = html;
            
            setTimeout(() => {
                createChannelChart();
                createKategoriChart();
                createImpactChart();
            }, 100);
            
            if (!isMapInitialized) {
                map = L.map('map').setView([-6.5, 107], 10);
                L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
                    attribution: '© OpenStreetMap',
                    maxZoom: 19
                }).addTo(map);
                isMapInitialized = true;
            }
            if (current) setTimeout(() => initMap(current.Bulan, current.Tahun), 200);
            
            const btnShowMap = document.getElementById('btn-show-map');
            if (btnShowMap) {
                const newBtn = btnShowMap.cloneNode(true);
                btnShowMap.parentNode.replaceChild(newBtn, btnShowMap);
                newBtn.addEventListener('click', () => {
                    const [bulan, tahun] = document.getElementById('month-select').value.split('|');
                    initMap(bulan, tahun);
                });
            }
            
            let latestDampak = null;
            for (let i = dataDampak.length - 1; i >= 0; i--) {
                const d = dataDampak[i];
                const hasData = (d.Kualitas_Layanan > 0 || d.Kepatuhan > 0 || d.Pengawasan > 0);
                if (hasData) {
                    latestDampak = d;
                    break;
                }
            }
            if (!latestDampak && dataDampak.length > 0) {
                latestDampak = dataDampak[dataDampak.length - 1];
            }
            
            const tbody = document.getElementById('dampak-table-body');
            if (tbody && latestDampak) {
                const dampakItems = [
                    { nama: 'Dampak Kualitas Layanan & SLA', jumlah: latestDampak.Kualitas_Layanan || 0, threshold: 30, rekomendasi: 'Review SOP', pic: 'Sie Layanan' },
                    { nama: 'Dampak Kepatuhan & Regulasi', jumlah: latestDampak.Kepatuhan || 0, threshold: 10, rekomendasi: 'Koordinasi PKC', pic: 'Seksi PKC' },
                    { nama: 'Pengawasan & Penegakan Hukum', jumlah: latestDampak.Pengawasan || 0, threshold: 10, rekomendasi: 'Operasi gabungan', pic: 'Seksi Intel' },
                    { nama: 'Dampak Hubungan Pemangku Kepentingan', jumlah: latestDampak.Stakeholder || 0, threshold: 5, rekomendasi: 'Komunikasi intensif', pic: 'Seksi Humas' },
                    { nama: 'Dampak SDM & Proses Internal', jumlah: latestDampak.SDM || 0, threshold: 3, rekomendasi: 'Evaluasi kinerja', pic: 'Seksi SDM' },
                    { nama: 'Perlu Review Manual/Tidak terkait pada MR', jumlah: latestDampak.Review_Manual || 0, threshold: 2, rekomendasi: 'Review prosedur', pic: 'Tim MR' },
                    { nama: 'Dampak Reputasi & Persepsi Publik', jumlah: latestDampak.Reputasi || 0, threshold: 4, rekomendasi: 'Strategi komunikasi', pic: 'Sie Humas' }
                ];
                tbody.innerHTML = dampakItems.map(d => {
                    let status = d.jumlah >= d.threshold * 2 ? '🔴 Darurat' : (d.jumlah >= d.threshold ? '🟡 Waspada' : '🟢 Normal');
                    return `<tr><td>${d.nama}</td><td>${d.jumlah}</td><td>${d.threshold}</td><td>${status}</td><td>${d.rekomendasi} (PIC: ${d.pic})</td></tr>`;
                }).join('');
            }
        }
        
        // Global function untuk toggle dataset (opsional)
        window.toggleCategoryDataset = function(index) {
            if (kategoriChart && kategoriChart.data.datasets[index]) {
                const dataset = kategoriChart.data.datasets[index];
                dataset.hidden = !dataset.hidden;
                kategoriChart.update();
            }
        };
        
        fetchAllData();
    </script>
</body>
</html>
