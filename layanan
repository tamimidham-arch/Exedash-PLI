        function getWaktuChangeText(current, previous) {
            if (!previous) return 'Data awal';
            const toSeconds = (t) => { if (!t) return 0; const p = t.split(':'); return (parseInt(p[0])||0)*3600 + (parseInt(p[1])||0)*60 + (parseInt(p[2])||0); };
            const diff = toSeconds(previous) - toSeconds(current);
            const mins = Math.floor(Math.abs(diff) / 60);
            if (diff > 0) return `▲ Lebih cepat ${mins} menit`;
            if (diff < 0) return `▼ Lebih lambat ${mins} menit`;
            return '→ Sama';
        }
        
        function parseDateFromAduan(timestamp) {
            if (!timestamp) return null;
            const dateStr = timestamp.split(' ')[0];
            const [year, month, day] = dateStr.split('-');
            return { year, month: parseInt(month), monthName: getMonthName(parseInt(month)) };
        }
        
        function getMonthName(month) {
            const months = ['Januari', 'Februari', 'Maret', 'April', 'Mei', 'Juni', 'Juli', 'Agustus', 'September', 'Oktober', 'November', 'Desember'];
            return months[month - 1];
        }
        
        function initMap(month, year) {
            if (!map) return;
            if (currentMarkers.length) {
                currentMarkers.forEach(marker => map.removeLayer(marker));
                currentMarkers = [];
            }
            
            const filteredAduan = dataAduan.filter(aduan => {
                if (!aduan.timestamp) return false;
                const parsed = parseDateFromAduan(aduan.timestamp);
                if (!parsed) return false;
                return parsed.monthName === month && parsed.year === year;
            });
            
            if (filteredAduan.length === 0) {
                L.popup().setLatLng([-6.5, 107]).setContent(`📭 Tidak ada data aduan untuk ${month} ${year}`).openOn(map);
                map.setView([-6.5, 107], 10);
                return;
            }
            
            const locationMap = new Map();
            filteredAduan.forEach(aduan => {
                const lat = parseFloat(aduan.lat);
                const lng = parseFloat(aduan.lon);
                if (isNaN(lat) || isNaN(lng)) return;
                const key = `${lat},${lng}`;
                if (locationMap.has(key)) {
                    locationMap.get(key).jumlahAduan += 1;
                } else {
                    locationMap.set(key, { lat, lng, nama: aduan.lokasi_lengkap?.split(',')[0] || 'Lokasi', alamatLengkap: aduan.lokasi_lengkap || '', provinsi: aduan.provinsi || '', jumlahAduan: 1 });
                }
            });
            
            const aduanValues = Array.from(locationMap.values()).map(l => l.jumlahAduan);
            const maxAduan = aduanValues.length > 0 ? Math.max(...aduanValues) : 1;
            
            locationMap.forEach(location => {
                const radius = 12 + (location.jumlahAduan / maxAduan) * 36;
                let color = location.jumlahAduan >= 5 ? '#dc3545' : (location.jumlahAduan >= 3 ? '#ffc107' : '#28a745');
                const customIcon = L.divIcon({
                    className: 'custom-marker',
                    html: `<div style="background-color: ${color}; width: ${radius}px; height: ${radius}px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; font-size: ${Math.max(10, radius/2)}px;">${location.jumlahAduan}</div>`,
                    iconSize: [radius, radius]
                });
                const marker = L.marker([location.lat, location.lng], { icon: customIcon });
                marker.bindPopup(`<b>${location.nama}</b><br>${location.alamatLengkap}<br>Total Aduan: ${location.jumlahAduan}`);
                marker.addTo(map);
                currentMarkers.push(marker);
            });
            
            if (locationMap.size > 0) {
                const bounds = L.latLngBounds(Array.from(locationMap.values()).map(l => [l.lat, l.lng]));
                map.fitBounds(bounds, { padding: [50, 50] });
            }
        }
        
        function formatTrendText(trend) {
            if (!trend || trend === '') return 'Data tidak tersedia';
            const trendStr = trend.toString();
            if (trendStr.includes('+') || trendStr.includes('▲')) {
                const value = trendStr.replace(/[^0-9]/g, '');
                return `<span class="trend-up">▲ +${value}</span>`;
            } else if (trendStr.includes('-') || trendStr.includes('▼')) {
                const value = trendStr.replace(/[^0-9]/g, '');
                return `<span class="trend-down">▼ -${value}</span>`;
            }
            return `<span class="trend-stable">→ ${trendStr}</span>`;
        }
        
